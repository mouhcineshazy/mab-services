# Copy this to .env.local and fill in your values

# Resend — https://resend.com (free: 3,000 emails/month)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_TO_EMAIL=your-email@example.com

# Public base URL (no trailing slash)
NEXT_PUBLIC_BASE_URL=https://your-domain.com

# Cal.com — https://cal.com (free tier)
# API key: Settings → Developer → API Keys in your Cal.com dashboard (server-side only)
# Username: your Cal.com username (e.g. m-benzakour)
# Event slugs: the URL slugs of your event types in Cal.com
CAL_API_KEY=cal_live_xxxxxxxxxxxx
NEXT_PUBLIC_CAL_USERNAME=your-cal-username
NEXT_PUBLIC_CAL_EVENT_SLUG=your-masterclass-slug
NEXT_PUBLIC_CAL_CONSULTATION_SLUG=your-consultation-slug
